# ==============================================================================
# Traefik-One: Plantilla de Variables de Entorno (.env.example)
# ==============================================================================
# Copia este archivo como ".env" y edita los valores para tu entorno real:
# cp env.example .env
# ==============================================================================

# 1. Dominio Principal del Servidor
# Se utiliza para resolver la URL del dashboard de Traefik (ej: traefik.idmji.org)
DOMAIN=idmji.org

# 2. Correo de Contacto para Let's Encrypt
# Let's Encrypt enviará notificaciones de vencimiento o problemas a este correo.
EMAILS_FROM_EMAIL=tu-correo@ejemplo.com

# 3. Credenciales para el Dashboard de Traefik
# Acceso mediante HTTP Basic Auth.
USERNAME=admin

# Contraseña encriptada con algoritmo MD5 (apr1) o bcrypt.
# IMPORTANTE: No uses contraseñas en texto plano aquí.
# Para generar tu HASHED_PASSWORD ejecuta en tu terminal:
# echo $(htpasswd -nB user) | cut -d ':' -f 2
# O usa un generador online de htpasswd (con cifrado MD5/apr1).
# 
# Coloca tu hash de contraseña generado aquí (recuerda duplicar los signos $$ para escapar en docker-compose):
HASHED_PASSWORD=YOUR_HASHED_PASSWORD_HERE
